{
  "name": "agent-hub-bridge-vscode",
  "displayName": "agent-hub bridge (VS Code)",
  "description": "VS Code extension that connects to agent-hub: watch your inbox as notifications and send DMs via the @agent-hub Copilot Chat participant.",
  "version": "0.11.1",
  "publisher": "kishibashi3",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kishibashi3/agent-hub-bridge-vscode.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "chatParticipants": [
      {
        "id": "agent-hub.participant",
        "name": "agent-hub",
        "description": "Send DMs to agent-hub participants from Copilot Chat. Usage: @agent-hub @<handle> <message>",
        "isSticky": false
      }
    ],
    "commands": [
      {
        "command": "agentHubBridge.start",
        "title": "agent-hub bridge: Start inbox watch"
      },
      {
        "command": "agentHubBridge.stop",
        "title": "agent-hub bridge: Stop inbox watch"
      },
      {
        "command": "agentHubBridge.status",
        "title": "agent-hub bridge: Show connection status"
      },
      {
        "command": "agentHubBridge.setGithubPat",
        "title": "agent-hub bridge: Set GitHub PAT (secret storage)"
      },
      {
        "command": "agentHubBridge.clearGithubPat",
        "title": "agent-hub bridge: Clear GitHub PAT (secret storage)"
      }
    ],
    "configuration": {
      "title": "agent-hub bridge",
      "properties": {
        "agentHubBridge.url": {
          "type": "string",
          "default": "http://localhost:3000/mcp",
          "description": "agent-hub MCP endpoint URL."
        },
        "agentHubBridge.user": {
          "type": "string",
          "default": "",
          "description": "Handle to register as (trust mode), or to override in pat mode. Required in trust mode."
        },
        "agentHubBridge.tenant": {
          "type": "string",
          "default": "",
          "description": "Tenant identifier (X-Tenant-Id). Leave blank for default tenant."
        },
        "agentHubBridge.defaultHandle": {
          "type": "string",
          "default": "",
          "description": "Default DM recipient when no @handle is given and no sticky handle is set (e.g. @planner). Leave blank to use sticky handle or show usage hint. Type @@ to open the participant picker."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit -p ./",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "tsx --test tests/**/*.test.ts",
    "test:watch": "tsx --test --watch tests/**/*.test.ts",
    "package": "vsce package --no-yarn",
    "package:check": "vsce package --no-yarn --out /tmp/agent-hub-bridge-vscode-ci.vsix",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "@kishibashi3/agent-hub-sdk": "file:../agent-hub-sdk/js"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.12",
    "eslint": "^10.4.0",
    "tsx": "^4.22.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.4"
  }
}
