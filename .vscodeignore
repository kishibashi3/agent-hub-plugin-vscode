# vsce ships the contents of the repo MINUS what's matched here.
#
# What we WANT in the .vsix (everything else is excluded):
#   - dist/extension.js          (esbuild CJS bundle — the extension entry point)
#   - dist/extension.js.map      (only present in dev builds; omitted in production)
#   - package.json
#   - README.md
#   - LICENSE
#   - CHANGELOG.md
#
# The SDK and all other runtime dependencies are inlined into
# dist/extension.js by esbuild, so node_modules/ is excluded entirely —
# no per-package re-include needed.

# Source — dist/extension.js (esbuild bundle) is what ships.
src/**
tests/**

# Build / dev config
tsconfig.json
esbuild.mjs
.vscode-test/
.vscode/
eslint.config.mjs

# CI / tooling
.github/
.gitignore
.gitattributes

# TypeScript source files (dist/ may contain .js.map but never .ts)
**/*.ts

# Lockfile + node_modules — all runtime deps are bundled by esbuild.
package-lock.json
node_modules/

# Legacy tsc output directory (kept here in case a stale out/ exists
# from a pre-0.5.0 checkout; esbuild writes to dist/ instead).
out/

# Docs we don't ship (PR templates, ADRs, internal notes if any later)
docs/

# Internal project conventions / role doc — not part of the user-facing
# distribution.
CLAUDE.md

# Editor cruft
*.log
.DS_Store
