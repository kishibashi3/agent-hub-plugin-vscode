# vsce ships the contents of the repo MINUS what's matched here.
#
# What we WANT in the .vsix (everything else is excluded):
#   - out/**/*.js + out/**/*.js.map  (runtime + debug sourcemaps)
#   - package.json
#   - README.md
#   - LICENSE
#   - CHANGELOG.md
#
# Everything else is build artefact / source / dev-only and stays out.

# Source — the compiled out/ is what ships.
src/**
tests/**

# Build / dev config
tsconfig.json
.vscode-test/
.vscode/
eslint.config.mjs

# CI / tooling
.github/
.gitignore
.gitattributes

# Test / typescript leftovers
**/*.ts
!out/**/*.d.ts

# Lockfile + manifests — `package.json` is needed by vsce / VS Code, the
# lockfile is dev-only. node_modules is excluded by default, but we
# re-include the SDK so the runtime `require('@kishibashi3/agent-hub-sdk')`
# inside the .vsix resolves. npm `install-links=true` (see `.npmrc`)
# ensures `node_modules/@kishibashi3/agent-hub-sdk/` is a real copy of
# the SDK's `files: []` ship surface (= `dist/` + `src/` + manifests)
# rather than a symlink to a sibling checkout, so the include below
# only catches the SDK's own published artefacts — no nested
# devDependencies follow along.
package-lock.json
node_modules/
!node_modules/@kishibashi3/
!node_modules/@kishibashi3/agent-hub-sdk/**

# Docs we don't ship (PR templates, ADRs, internal notes if any later)
docs/

# Internal project conventions / role doc — not part of the user-facing
# distribution.
CLAUDE.md

# Editor cruft
*.log
.DS_Store
